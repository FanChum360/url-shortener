# Application
APP_NAME=URL Shortener
APP_VERSION=1.0.0
DEBUG=false
BASE_URL=http://localhost:8000

# Database (change for production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urlshortener

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Security (CHANGE IN PRODUCTION)
SECRET_KEY=change-me-in-production-use-secrets-manager

# Snowflake ID (unique per instance: 0-1023)
MACHINE_ID=1
DATACENTER_ID=1
